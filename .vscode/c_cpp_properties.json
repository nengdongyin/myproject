{
  "version": 4,
  "configurations": [
    {
      "name": "Zephyr",
      "intelliSenseMode": "linux-gcc-arm",
      "compilerPath": "${userHome}/.pico-sdk/zephyr_workspace/zephyr-sdk-1.0.1/arm-zephyr-eabi/bin/arm-zephyr-eabi-gcc",
      "includePath": [
        "${workspaceFolder}/**",
        "${workspaceFolder}/build/zephyr/include",
        "${userHome}/.pico-sdk/zephyr_workspace/zephyr-main/include",
        "${userHome}/.pico-sdk/zephyr_workspace/zephyr-main/modules/cmsis_6",
        "${userHome}/.pico-sdk/zephyr_workspace/zephyr-main/modules/hal_infineon",
        "${userHome}/.pico-sdk/zephyr_workspace/zephyr-main/modules/hal_rpi_pico"
      ],
      "compileCommands": "${workspaceFolder}/build/compile_commands.json",
      "cppStandard": "gnu++20",
      "cStandard": "gnu17",
      "forcedInclude": [
        "${userHome}/.pico-sdk/zephyr_workspace/zephyr-main/include/zephyr/devicetree.h",
        "${workspaceFolder}/build/zephyr/include/generated/zephyr/autoconf.h",
        "${workspaceFolder}/build/zephyr/include/generated/zephyr/version.h"
      ]
    }
  ]
}